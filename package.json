{
  "name": "gourmet-express",
  "version": "1.0.0",
  "description": "Sistema integral de gestión para restaurante - frontend estático",
  "private": true,
  "scripts": {
    "lint:js": "eslint . --ext .js || true",
    "lint:css": "stylelint \"**/*.css\" || true",
